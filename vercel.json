{
  "version": 2,
  "buildCommand": "pip install -r requirements.txt",
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python", "config": { "runtime": "python3.11", "maxDuration": 30 } },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/public/static/$1" },
    { "src": "/(.*)", "dest": "/api/index.py" }
  ],
  "env": {
    "PYTHONUNBUFFERED": "1"
  }
}
